# MyBaby — Environment Variables
# Copy to .env and fill in values

# =============================================================================
# REQUIRED
# =============================================================================

# Secret key for session signing (min 32 chars, K4)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-characters

# =============================================================================
# AUTH
# =============================================================================

# Auth mode: forward (Authelia), local (built-in), both, disabled
AUTH_MODE=forward

# Forward-auth header name (set by reverse proxy / Authelia)
AUTH_TRUSTED_HEADER=Remote-User

# Trusted proxy CIDR (only these IPs may set auth headers)
AUTH_TRUSTED_PROXIES=192.168.178.0/24

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path (relative to container workdir)
DATABASE_URL=sqlite:///app/data/mybaby.db

# =============================================================================
# APPLICATION
# =============================================================================

# Environment: dev, staging, prod
ENVIRONMENT=prod

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS origins (comma-separated, empty = disabled)
CORS_ORIGINS=

# CSRF protection (disable only for development)
CSRF_ENABLED=true

# Rate limit (requests per minute)
RATE_LIMIT=60/minute

# Max request body size in bytes (default 1MB)
REQUEST_SIZE_LIMIT=1048576
