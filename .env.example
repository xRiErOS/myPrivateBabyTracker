# MyBaby — Environment Variables
# Copy to .env and fill in values

# REQUIRED: Secret key for session signing (min 32 chars)
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-characters

# Database path (SQLite)
DATABASE_URL=sqlite:///data/mybaby.db

# Auth mode: forward (Authelia), local (built-in), both
AUTH_MODE=forward

# Forward-auth header name (set by reverse proxy)
AUTH_TRUSTED_HEADER=Remote-User

# Trusted proxy CIDR (only these IPs may set auth headers)
AUTH_TRUSTED_PROXIES=192.168.178.0/24

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS origins (comma-separated, empty = disabled)
CORS_ORIGINS=
